# Required — Project Settings → API in Supabase dashboard
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# API base: native always uses this. Web uses it when HTTPS and not localhost (Railway);
# otherwise web uses Metro /api proxy → local backend (see metro.config.js).
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
# Browser + Railway only (include https:// — hostname-only is auto-prefixed with https://):
# EXPO_PUBLIC_API_URL=https://yourstrat-production.up.railway.app
# Then: npm run web:remote --clear
