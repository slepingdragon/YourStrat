{
  "expo": {
    "name": "YourStrat",
    "slug": "yourstrat",
    "version": "1.0.0",
    "scheme": "yourstrat",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#08080B",
    "icon": "./assets/logo/yourstrat-star.png",
    "splash": {
      "image": "./assets/logo/yourstrat-star.png",
      "backgroundColor": "#08080B",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourstrat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "YourStrat uses the camera to scan meals and estimate nutrition.",
        "NSPhotoLibraryUsageDescription": "YourStrat needs photo library access so you can log meals from existing pictures."
      }
    },
    "android": {
      "package": "com.yourstrat.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/yourstrat-star.png",
        "backgroundColor": "#08080B"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "YourStrat uses the camera to scan meals."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "YourStrat needs photo library access."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5c5a8b9-7fbf-4521-8ce5-275a427a0062"
      }
    },
    "owner": "baniabradyy"
  }
}
