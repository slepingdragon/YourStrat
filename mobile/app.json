{
  "expo": {
    "name": "YourStrat",
    "slug": "yourstrat",
    "version": "1.0.0",
    "scheme": "yourstrat",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#08080B",
    "splash": {
      "backgroundColor": "#08080B",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourstrat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "YourStrat uses the camera to scan meals and estimate nutrition.",
        "NSPhotoLibraryUsageDescription": "YourStrat needs photo library access so you can log meals from existing pictures."
      }
    },
    "android": {
      "package": "com.yourstrat.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      ["expo-camera", { "cameraPermission": "YourStrat uses the camera to scan meals." }],
      ["expo-image-picker", { "photosPermission": "YourStrat needs photo library access." }]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "eas": { "projectId": "REPLACE_WITH_EAS_PROJECT_ID" }
    }
  }
}
