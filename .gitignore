# Native projects are regenerated by `expo prebuild` (or EAS Build does it
# automatically). Don't commit them — keeping them out lets EAS run its own
# fresh prebuild + autolinking, which is what makes cloud builds reproducible.
mobile/android/
mobile/ios/

.claude/settings.local.json
mobile/eas-build.log*
mobile/expo-smoke.log

# Google Play service account key — used by `eas submit` for Android.
# Never commit this; download from Play Console → API access.
mobile/play-service-account.json
play-service-account.json
