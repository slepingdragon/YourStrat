#!/bin/sh
# YourStrat token + scope guard (Stories 1.2 + 1.3). Logic lives in
# precommit_checks.py so it's testable on its own. Enable once per clone:
#   git config core.hooksPath .githooks
DIR="$(dirname "$0")"
if command -v python >/dev/null 2>&1; then
  exec python "$DIR/precommit_checks.py"
elif command -v python3 >/dev/null 2>&1; then
  exec python3 "$DIR/precommit_checks.py"
else
  echo "pre-commit: python not found; skipping YourStrat guards" >&2
  exit 0
fi
